# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=crm_db

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d

# ─── OpenAI-compatible AI (optional) ─────────────────────
# Supports any OpenAI-compatible API. Set KEY + BASE_URL + MODEL.
# Example custom endpoint (DeepSeek via hcnsec gateway):
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.hcnsec.cn/v1
#   OPENAI_MODEL=DeepSeek-V4-Flash
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ─── SMTP Email (optional) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Stripe (optional) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# ─── WhatsApp Business API (optional) ──────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── Gmail / Google OAuth (optional) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback

# ─── Microsoft / Outlook OAuth (optional) ──────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5001/api/auth/microsoft/callback

# ─── Frontend URL (CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
